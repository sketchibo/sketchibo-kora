import os, sqlite3, requests, datetime, glob, shutil

# Load Keys
API_KEYS = {}
if os.path.exists(os.path.expanduser("~/kora/.env")):
    with open(os.path.expanduser("~/kora/.env")) as f:
        for line in f:
            if "=" in line:
                k, v = line.strip().split("=", 1)
                API_KEYS[k] = v

ROOT = os.path.expanduser("~/kora")
DB = os.path.join(ROOT, "core/memory/index.db")
OLLAMA_URL = "http://localhost:11434/api/generate"

def call_local(model, prompt, sys):
    try:
        res = requests.post(OLLAMA_URL, json={"model": model, "prompt": f"SYS:{sys}\nUSER:{prompt}", "stream": False}, timeout=120)
        return res.json()['response']
    except: return "[Local Error]"

def call_perplexity(prompt):
    url = "https://api.perplexity.ai/chat/completions"
    headers = {"Authorization": f"Bearer {API_KEYS.get('PERPLEXITY_API_KEY')}", "Content-Type": "application/json"}
    data = {"model": "llama-3.1-sonar-large-128k-online", "messages": [{"role": "user", "content": prompt}]}
    try:
        res = requests.post(url, json=data, headers=headers)
        return res.json()['choices'][0]['message']['content']
    except: return "[Perplexity Connection Failed]"

